// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  nurse      // Healthcare caregiver
  admin      // Full portal access
  biller     // Third-party billing access
  provider   // Other medical provider (non-nurse)
  guardian   // Parent / family member of patient
}


model User {
  id         String   @id @default(uuid())
  email      String   @unique
  password   String
  // internal name shown to admin; set during account creation
  name       String
  role       Role     @default(nurse)

  // Admin-only MFA
  mfaSecret  String?
  mfaEnabled Boolean  @default(false)

  passwordResetToken  String?
  passwordResetExpiry DateTime?
  lastLoginAt         DateTime?

  nurseProfile NurseProfile?
  createdAt    DateTime @default(now())
}    


model NurseProfile {
  id         String   @id @default(uuid())
  userId     String   @unique
  displayName String  // name the nurse chooses for themselves

  accountNumber  String?  @unique

  // Individual provider — nurse-editable
  firstName      String?
  middleInitial  String?
  lastName       String?
  phone          String?
  address        String?
  city           String?
  state          String?
  zip            String?
  dob            String?   // stored as plain text date string
  ssnEncrypted   String?   // AES-256-GCM encrypted
  npiNumber      String?
  medicaidNumber String?
  bcbsPayorId    String?

  // Business provider — admin-managed, conditional
  hasBusinessProvider  Boolean @default(false)
  bizServiceAddress    String?
  bizEntityName        String?
  bizEmail             String?
  einEncrypted         String?   // AES-256-GCM encrypted
  feinEncrypted        String?   // AES-256-GCM encrypted
  bizNpi               String?
  bizMedicaidId        String?

  // Payment — admin-managed
  bankName             String?
  bankRoutingEncrypted String?   // AES-256-GCM encrypted
  bankAccountEncrypted String?   // AES-256-GCM encrypted

  // Onboarding & agreement
  onboardingComplete  Boolean   @default(false)
  enrolledInBilling   Boolean?
  carrierCount        Int?
  billingDurationType String?   // 'full_year' | 'policy_specific'
  billingDurationNote String?
  billingPlan         String?   // 'A1' | 'A2' | 'B' | 'custom'
  planStartDate       String?
  agreementSignedAt   DateTime?
  agreementSignature  String?
  agreementIp         String?

  // Legacy
  billingInfo  String?

  // Provider aliases for claim matching (e.g. ["Janine", "JCST"])
  providerAliases String[] @default([])

  user           User            @relation(fields: [userId], references: [id])
  timeEntries    TimeEntry[]
  claims         Claim[]
  enrollmentLogs EnrollmentLog[]
  invoices       Invoice[]
  reminders      NurseReminder[]
}

model GlobalEvent {
  id          String   @id @default(uuid())
  title       String
  description String?
  eventDate   DateTime
  category    String   @default("general") // 'tax' | 'renewal' | 'compliance' | 'general'
  targetRoles String[] @default([])        // empty = visible to all; otherwise ['nurse','biller',...]
  recurrence  String?                      // 'quarterly' | 'annual' | null (one-time)
  createdBy   String?                      // admin user id
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([eventDate])
}

model NurseReminder {
  id        String   @id @default(uuid())
  nurseId   String
  title     String
  category  String   @default("general") // 'license' | 'medicaid' | 'bcbs' | 'npi' | 'insurance' | 'general'
  dueDate   DateTime
  notes     String?
  completed Boolean  @default(false)
  createdAt DateTime @default(now())

  nurse NurseProfile @relation(fields: [nurseId], references: [id], onDelete: Cascade)

  @@index([nurseId])
}

model EnrollmentLog {
  id               String   @id @default(uuid())
  nurseId          String
  nurseDisplayName String
  action           String   // 'opted_out' | 'opted_in' | 're_enrolled'
  note             String?
  sentTo           String?
  emailSent        Boolean  @default(false)
  createdAt        DateTime @default(now())

  nurse NurseProfile @relation(fields: [nurseId], references: [id], onDelete: Cascade)
}

model TimeEntry {
  id        String   @id @default(uuid())
  nurseId   String
  workDate  DateTime
  hours     Float
  notes     String?
  billed    Boolean  @default(false)

  // Invoice flagging
  readyToInvoice Boolean @default(false)
  invoiceFeePlan String? // 'A1' | 'A2' | 'B' | 'C'
  invoiceFeeAmt  Float?
  invoiceId      String?
  invoice        Invoice? @relation(fields: [invoiceId], references: [id])
  claimRef       String?  // optional claim reference number for billing lookup

  createdAt DateTime @default(now())

  nurse     NurseProfile @relation(fields: [nurseId], references: [id])

  @@unique([nurseId, workDate])
}

model Invoice {
  id            String   @id @default(uuid())
  nurseId       String
  invoiceNumber String   @unique
  totalAmount   Float
  dueTerm       String   // '30' | '60' | '90' | 'ASAP'
  dueDate       DateTime
  status        String   @default("Pending") // Pending | Paid | Overdue | Cancelled
  notes         String?
  nurseEmail    String
  nurseName     String
  sentAt        DateTime @default(now())
  paidAt        DateTime?

  entries TimeEntry[]
  nurse   NurseProfile @relation(fields: [nurseId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PortalMessage {
  id        String   @id @default(uuid())
  title     String?
  body      String
  category  String   @default("General") // Claims | Invoices | Events | General
  audiences String[] @default([])        // 'All Users' | 'All Nurses' | 'Active Billing' | 'Non-Provider' | 'Admins' | 'user:{nurseProfileId}'
  createdBy String?                      // admin user id
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([createdAt])
}

model FaqItem {
  id        String   @id @default(uuid())
  question  String
  answer    String
  category  String   @default("General")
  sortOrder Int      @default(0)
  published Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Claim {
  id           String @id @default(uuid())
  nurseId      String

  // Claim Submission Details
  claimId      String?
  providerName String?
  dosStart     DateTime?
  dosStop      DateTime?
  totalBilled  Float?
  claimStage   String?

  // Primary Insurance
  primaryPayer        String?
  primaryAllowedAmt   Float?
  primaryPaidAmt      Float?
  primaryPaidDate     DateTime?
  primaryPaidTo       String?

  // Secondary Insurance
  secondaryPayer      String?
  secondaryAllowedAmt Float?
  secondaryPaidAmt    Float?
  secondaryPaidDate   DateTime?
  secondaryPaidTo     String?

  // Summary
  totalReimbursed    Float?
  remainingBalance   Float?
  dateFullyFinalized DateTime?

  // Notes
  processingNotes    String?

  // Resubmission tracking
  resubmissionOf     String?  // claimId of the original rejected claim

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  nurse NurseProfile @relation(fields: [nurseId], references: [id], onDelete: Cascade)

  @@index([nurseId])
  @@index([claimId])
}
