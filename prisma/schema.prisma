// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum Role {
  nurse
  admin
}

enum ClaimStatus {
  drafted
  submitted
  pending
  paid
  denied
  appealed
  voided
}

model User {
  id         String   @id @default(uuid())
  email      String   @unique
  password   String
  // internal name shown to admin; set during account creation
  name       String
  role       Role     @default(nurse)

  // Admin-only MFA
  mfaSecret  String?
  mfaEnabled Boolean  @default(false)

  nurseProfile NurseProfile?
  createdAt  DateTime @default(now())
}    


model NurseProfile {
  id         String   @id @default(uuid())
  userId     String   @unique
  displayName String  // name the nurse chooses for themselves

  // optional profile information nurses can edit
  address      String?
  city         String?
  state        String?
  zip          String?
  npiNumber    String?
  medicaidNumber String?
  billingInfo  String?

  user      User     @relation(fields: [userId], references: [id])
  timeEntries TimeEntry[]
  claims     Claim[]
}

model TimeEntry {
  id        String   @id @default(uuid())
  nurseId   String
  workDate  DateTime
  hours     Float
  notes     String?
  createdAt DateTime @default(now())

  nurse     NurseProfile @relation(fields: [nurseId], references: [id])

  @@unique([nurseId, workDate])
}

model Claim {
  id              String      @id @default(uuid())
  nurseId          String
  internalClaimId  String      @unique

  periodStart      DateTime
  periodEnd        DateTime

  status           ClaimStatus @default(drafted)

  hoursBilled       Float?
  chargeAmount      Float?
  allowedAmount     Float?
  paidAmount        Float?

  carcCodes         String?   // store as "CO-45, PR-1" etc
  statusNote        String?

  submittedAt       DateTime?
  paidAt            DateTime?

  createdAt         DateTime @default(now())

  nurse            NurseProfile @relation(fields: [nurseId], references: [id])
}
