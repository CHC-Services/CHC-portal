// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  nurse      // Healthcare caregiver
  admin      // Full portal access
  biller     // Third-party billing access
  provider   // Other medical provider (non-nurse)
  guardian   // Parent / family member of patient
}


model User {
  id         String   @id @default(uuid())
  email      String   @unique
  password   String
  // internal name shown to admin; set during account creation
  name       String
  role       Role     @default(nurse)

  // Admin-only MFA
  mfaSecret  String?
  mfaEnabled Boolean  @default(false)

  passwordResetToken  String?
  passwordResetExpiry DateTime?

  nurseProfile NurseProfile?
  createdAt    DateTime @default(now())
}    


model NurseProfile {
  id         String   @id @default(uuid())
  userId     String   @unique
  displayName String  // name the nurse chooses for themselves

  accountNumber  String?  @unique

  // Individual provider — nurse-editable
  firstName      String?
  middleInitial  String?
  lastName       String?
  phone          String?
  address        String?
  city           String?
  state          String?
  zip            String?
  dob            String?   // stored as plain text date string
  ssnEncrypted   String?   // AES-256-GCM encrypted
  npiNumber      String?
  medicaidNumber String?
  bcbsPayorId    String?

  // Business provider — admin-managed, conditional
  hasBusinessProvider  Boolean @default(false)
  bizServiceAddress    String?
  bizEntityName        String?
  bizEmail             String?
  einEncrypted         String?   // AES-256-GCM encrypted
  feinEncrypted        String?   // AES-256-GCM encrypted
  bizNpi               String?
  bizMedicaidId        String?

  // Payment — admin-managed
  bankName             String?
  bankRoutingEncrypted String?   // AES-256-GCM encrypted
  bankAccountEncrypted String?   // AES-256-GCM encrypted

  // Onboarding & agreement
  onboardingComplete  Boolean   @default(false)
  enrolledInBilling   Boolean?
  carrierCount        Int?
  billingDurationType String?   // 'full_year' | 'policy_specific'
  billingDurationNote String?
  billingPlan         String?   // 'A1' | 'A2' | 'B' | 'custom'
  planStartDate       String?
  agreementSignedAt   DateTime?
  agreementSignature  String?
  agreementIp         String?

  // Legacy
  billingInfo  String?

  user           User            @relation(fields: [userId], references: [id])
  timeEntries    TimeEntry[]
  claims         Claim[]
  enrollmentLogs EnrollmentLog[]
}

model EnrollmentLog {
  id               String   @id @default(uuid())
  nurseId          String
  nurseDisplayName String
  action           String   // 'opted_out' | 'opted_in' | 're_enrolled'
  note             String?
  sentTo           String?
  emailSent        Boolean  @default(false)
  createdAt        DateTime @default(now())

  nurse NurseProfile @relation(fields: [nurseId], references: [id], onDelete: Cascade)
}

model TimeEntry {
  id        String   @id @default(uuid())
  nurseId   String
  workDate  DateTime
  hours     Float
  notes     String?
  billed    Boolean  @default(false)
  createdAt DateTime @default(now())

  nurse     NurseProfile @relation(fields: [nurseId], references: [id])

  @@unique([nurseId, workDate])
}

model Claim {
  id                String   @id @default(uuid())
  nurseId           String

  claimCtrlId       String?
  transId           String?
  submitStatus      String?
  submitDate        DateTime?
  status            String?
  dosStart          DateTime?
  dosStop           DateTime?
  hoursBilled       Float?
  chargeAmount      Float?   // Billed
  allowedAmount     Float?   // Allowed
  paidAmount        Float?   // BCBS Paid
  remitCheckNumber  String?  // Remit / Check #
  checkAmount       Float?   // Check $
  finalizedDate     DateTime?
  eobDate           DateTime?
  statusNote        String?  // Comments
  innOon            String?  // INN / OON
  dedCoin           Float?   // DED / COIN
  allowRate         Float?   // Allow Rate

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  nurse             NurseProfile @relation(fields: [nurseId], references: [id], onDelete: Cascade)

  @@index([nurseId])
  @@index([claimCtrlId])
}
