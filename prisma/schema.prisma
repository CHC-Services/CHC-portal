// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  nurse      // Healthcare caregiver
  admin      // Full portal access
  biller     // Third-party billing access
  provider   // Other medical provider (non-nurse)
  guardian   // Parent / family member of patient
}


model User {
  id         String   @id @default(uuid())
  email      String   @unique
  password   String
  // internal name shown to admin; set during account creation
  name       String
  role       Role     @default(nurse)

  // Admin-only MFA
  mfaSecret  String?
  mfaEnabled Boolean  @default(false)

  passwordResetToken  String?
  passwordResetExpiry DateTime?
  lastLoginAt         DateTime?

  nurseProfile NurseProfile?
  createdAt    DateTime @default(now())
}    


model NurseProfile {
  id         String   @id @default(uuid())
  userId     String   @unique
  displayName String  // name the nurse chooses for themselves

  accountNumber  String?  @unique

  // Individual provider — nurse-editable
  firstName      String?
  middleInitial  String?
  lastName       String?
  phone          String?
  address        String?
  city           String?
  state          String?
  zip            String?
  dob            String?   // stored as plain text date string
  ssnEncrypted   String?   // AES-256-GCM encrypted
  npiNumber      String?
  medicaidNumber String?

  // Business provider — admin-managed, conditional
  hasBusinessProvider  Boolean @default(false)
  bizServiceAddress    String?
  bizEntityName        String?
  bizPhone             String?
  bizEmail             String?
  einEncrypted         String?   // AES-256-GCM encrypted
  feinEncrypted        String?   // AES-256-GCM encrypted
  bizNpiType           String?   // 'Type1' | 'Type2'
  bizNpi               String?
  bizMedicaidId        String?
  bizCity              String?
  bizState             String?
  bizZip               String?

  // Payment — admin-managed
  bankName             String?
  bankRoutingEncrypted String?   // AES-256-GCM encrypted
  bankAccountEncrypted String?   // AES-256-GCM encrypted

  // Onboarding & agreement
  onboardingComplete  Boolean   @default(false)
  enrolledInBilling   Boolean?
  carrierCount        Int?
  billingDurationType String?   // 'full_year' | 'policy_specific'
  billingDurationNote String?
  billingPlan         String?   // 'A1' | 'A2' | 'B' | 'custom'
  planStartDate       String?
  agreementSignedAt   DateTime?
  agreementSignature  String?
  agreementIp         String?

  // Legacy
  billingInfo  String?

  // Provider aliases for claim matching (e.g. ["Janine", "JCST"])
  providerAliases String[] @default([])

  // Notification preferences — reminders
  receiveNotifications    Boolean @default(true)  // weekly hour submission reminder (legacy)
  notifyBillingReminder   Boolean @default(true)  // billing-related reminders
  notifyDocExpiring       Boolean @default(true)  // document/license expiration reminders
  // Notification preferences — alerts
  notifyNewDocument       Boolean @default(true)  // alert when admin uploads a document
  notifyNewClaim          Boolean @default(true)  // alert when a new claim is added

  // Directory opt-in
  dirOptIn     Boolean @default(true)
  dirShowEmail Boolean @default(true)
  dirShowPhone Boolean @default(true)

  user             User               @relation(fields: [userId], references: [id])
  timeEntries      TimeEntry[]
  claims           Claim[]
  enrollmentLogs   EnrollmentLog[]
  invoices         Invoice[]
  reminders        NurseReminder[]
  documents        NurseDocument[]
  invoiceActivities InvoiceActivity[]
  caseAssignments  CaseAssignment[]
}

model GlobalEvent {
  id          String   @id @default(uuid())
  title       String
  description String?
  eventDate   DateTime
  category    String   @default("general") // 'tax' | 'renewal' | 'compliance' | 'general'
  targetRoles String[] @default([])        // empty = visible to all; otherwise ['nurse','biller',...]
  recurrence  String?                      // 'quarterly' | 'annual' | null (one-time)
  createdBy   String?                      // admin user id
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([eventDate])
}

model NurseReminder {
  id        String   @id @default(uuid())
  nurseId   String
  title     String
  category  String   @default("general") // 'license' | 'medicaid' | 'bcbs' | 'npi' | 'insurance' | 'general'
  dueDate   DateTime
  notes     String?
  completed Boolean  @default(false)
  createdAt DateTime @default(now())

  nurse NurseProfile @relation(fields: [nurseId], references: [id], onDelete: Cascade)

  @@index([nurseId])
}

model EnrollmentLog {
  id               String   @id @default(uuid())
  nurseId          String
  nurseDisplayName String
  action           String   // 'opted_out' | 'opted_in' | 're_enrolled'
  note             String?
  sentTo           String?
  emailSent        Boolean  @default(false)
  createdAt        DateTime @default(now())

  nurse NurseProfile @relation(fields: [nurseId], references: [id], onDelete: Cascade)
}

model TimeEntry {
  id        String   @id @default(uuid())
  nurseId   String
  workDate  DateTime
  hours     Float
  notes     String?
  billed    Boolean  @default(false)

  // Invoice flagging
  readyToInvoice Boolean @default(false)
  invoiceFeePlan String? // 'A1' | 'A2' | 'B' | 'C'
  invoiceFeeAmt  Float?
  invoiceId      String?
  invoice        Invoice? @relation(fields: [invoiceId], references: [id])
  claimRef       String?  // optional claim reference number for billing lookup

  createdAt DateTime @default(now())

  nurse     NurseProfile @relation(fields: [nurseId], references: [id])

  @@unique([nurseId, workDate])
}

model Invoice {
  id            String   @id @default(uuid())
  nurseId       String
  invoiceNumber String   @unique
  totalAmount   Float
  paidAmount    Float    @default(0)
  dueTerm       String   // '30' | '60' | '90' | 'ASAP'
  dueDate       DateTime
  status        String   @default("Sent") // Sent | Partial | Paid | Disputed | WrittenOff | Overdue
  notes         String?
  nurseEmail    String
  nurseName     String
  sentAt        DateTime @default(now())
  paidAt        DateTime?
  s3Key         String?

  entries           TimeEntry[]
  payments          Payment[]
  activities        InvoiceActivity[]
  nurse             NurseProfile @relation(fields: [nurseId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Payment {
  id            String   @id @default(uuid())
  invoiceId     String
  receiptNumber String   @unique
  amount        Float
  method        String?  // Venmo | Zelle | CashApp | ApplePay | Check | ACH | Other
  note          String?
  s3Key         String?
  appliedAt     DateTime @default(now())
  invoice       Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

model InvoiceActivity {
  id           String   @id @default(uuid())
  nurseId      String
  invoiceId    String?
  action       String   // 'Email' | 'Print'
  documentType String   // 'Invoice' | 'Statement' | 'Receipt'
  reference    String?  // e.g. invoice number, receipt number, or "Full Statement"
  note         String?
  createdAt    DateTime @default(now())

  nurse   NurseProfile @relation(fields: [nurseId], references: [id], onDelete: Cascade)
  invoice Invoice?     @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
}

model PortalMessage {
  id        String   @id @default(uuid())
  title     String?
  body      String
  category  String   @default("General") // Claims | Invoices | Events | General
  audiences String[] @default([])        // 'All Users' | 'All Nurses' | 'Active Billing' | 'Non-Provider' | 'Admins' | 'user:{nurseProfileId}'
  createdBy String?                      // admin user id
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([createdAt])
}

model AdminIdea {
  id        String   @id @default(uuid())
  body      String
  category  String   @default("Task")
  completed Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([completed])
}

model DocumentCategory {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now())
}

model NurseDocument {
  id              String    @id @default(uuid())
  nurseId         String
  nurse           NurseProfile @relation(fields: [nurseId], references: [id], onDelete: Cascade)
  title           String
  fileName        String
  storageKey      String       // S3 object key — never a public URL
  category        String       @default("General") // EOB | License | Contract | Tax | Other | General
  fileSize        Int?
  mimeType        String?
  uploadedBy      String
  nurseUploaded   Boolean   @default(false)  // true when nurse uploaded it themselves
  visibleToNurse  Boolean   @default(false)  // admin must explicitly share with nurse
  sharedWithAdmin Boolean   @default(false)  // nurse chose to share with admin
  adminReviewed   Boolean   @default(false)  // admin has acknowledged the shared doc
  claimId         String?   // links to Claim.id for EOB documents
  expiresAt       DateTime?
  reminderDays    Int[]        @default([])
  remindersSentDays Int[]      @default([])
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([nurseId])
  @@index([expiresAt])
  @@index([claimId])
}

model SystemSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model PendingNotification {
  id        String   @id @default(uuid())
  nurseId   String
  type      String   // 'claim' | 'document'
  payload   Json     // { claimId?, documentTitle?, category?, dosStart?, dosStop?, totalBilled? }
  createdAt DateTime @default(now())

  @@index([nurseId])
}

model NotificationBatch {
  id           String                   @id @default(uuid())
  sentAt       DateTime                 @default(now())
  trigger      String                   @default("manual") // 'manual' | 'import' | 'cron'
  totalSent    Int                      @default(0)
  totalSkipped Int                      @default(0)
  entries      NotificationBatchEntry[]

  @@index([sentAt])
}

model NotificationBatchEntry {
  id         String            @id @default(uuid())
  batchId    String
  nurseId    String
  nurseName  String
  nurseEmail String
  claims     Json              // [{claimId, dosStart, dosStop, totalBilled}]
  documents  Json              // [{documentTitle, category}]
  sentOk     Boolean           @default(true)
  batch      NotificationBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@index([batchId])
  @@index([nurseId])
}

model FaqItem {
  id          String   @id @default(uuid())
  question    String
  answer      String
  category    String   @default("General")
  subcategory String   @default("")
  sortOrder   Int      @default(0)
  published   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model PromptPayDocument {
  id        String   @id @default(uuid())
  claimRef  String   // claimId text e.g. "CLM-0042"
  claimDbId String?  // Claim.id DB UUID (optional)
  s3Key     String
  fileName  String
  version   Int
  createdAt DateTime @default(now())

  @@index([claimRef])
}

model ClaimReminder {
  id         String   @id @default(uuid())
  claimDbId  String   // Claim.id (DB UUID)
  claimRef   String?  // Claim.claimId (display ID e.g. "CLM-0042")
  nurseId    String?  // which provider the claim belongs to
  dueDate    DateTime
  reason     String
  completed  Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([claimDbId])
  @@index([dueDate])
}

model Claim {
  id           String @id @default(uuid())
  nurseId      String

  // Claim Submission Details
  claimId      String?
  providerName String?
  dosStart     DateTime?
  dosStop      DateTime?
  totalBilled  Float?
  claimStage   String?
  submitDate   DateTime?  // date the claim was submitted to insurance

  // Prompt Pay tracking
  submitDateReminderSentAt DateTime?  // set when the 28-day alert email fires

  // Primary Insurance
  primaryPayer        String?
  primaryAllowedAmt   Float?
  primaryPaidAmt      Float?
  primaryPaidDate     DateTime?
  primaryPaidTo       String?

  // Secondary Insurance
  secondaryPayer      String?
  secondaryAllowedAmt Float?
  secondaryPaidAmt    Float?
  secondaryPaidDate   DateTime?
  secondaryPaidTo     String?

  // Summary
  totalReimbursed    Float?
  remainingBalance   Float?
  dateFullyFinalized DateTime?

  // Notes
  processingNotes    String?

  // Resubmission tracking
  resubmissionOf     String?  // claimId of the original rejected claim

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  nurse NurseProfile @relation(fields: [nurseId], references: [id], onDelete: Cascade)

  @@index([nurseId])
  @@index([claimId])
}

model HomeCase {
  id               String           @id @default(uuid())
  patientFirstName String
  notes            String?
  active           Boolean          @default(true)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  assignments      CaseAssignment[]

  @@index([active])
}

model CaseAssignment {
  id       String      @id @default(uuid())
  caseId   String
  nurseId  String
  joinedAt DateTime    @default(now())

  homeCase HomeCase     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  nurse    NurseProfile @relation(fields: [nurseId], references: [id], onDelete: Cascade)

  @@unique([caseId, nurseId])
  @@index([caseId])
  @@index([nurseId])
}
